rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userRole() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isSuperadmin() {
      return userRole() == 'superadmin';
    }

    function isAdminOrAbove() {
      return userRole() == 'superadmin' || userRole() == 'admin';
    }

    match /users/{userId} {
      allow create: if signedIn();

      // User can read their own doc; superadmin/admin can read any
      allow get:  if signedIn() && (request.auth.uid == userId || isAdminOrAbove());
      allow list: if signedIn() && isAdminOrAbove();
      allow read: if signedIn() && (request.auth.uid == userId || isAdminOrAbove());

      // User can update own profile — but NOT the role field
      allow update: if signedIn()
                       && request.auth.uid == userId
                       && !('role' in request.resource.data.diff(resource.data).affectedKeys());

      // Only superadmin can change any user's role
      allow update: if isSuperadmin();
    }

    match /roleAuditLog/{docId} {
      allow create: if isSuperadmin();
      allow read:   if isSuperadmin();
    }

    // ── Test collections — admin and superadmin can manage ─────────────────────

    match /tests/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdminOrAbove();
    }

    match /skillReadingTests/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdminOrAbove();
    }

    // Level-based test collections
    match /a1Tests/{docId} { allow read: if signedIn(); allow create, update, delete: if isAdminOrAbove(); }
    match /a2Tests/{docId} { allow read: if signedIn(); allow create, update, delete: if isAdminOrAbove(); }
    match /b1Tests/{docId} { allow read: if signedIn(); allow create, update, delete: if isAdminOrAbove(); }
    match /b2Tests/{docId} { allow read: if signedIn(); allow create, update, delete: if isAdminOrAbove(); }
    match /c1Tests/{docId} { allow read: if signedIn(); allow create, update, delete: if isAdminOrAbove(); }
    match /c2Tests/{docId} { allow read: if signedIn(); allow create, update, delete: if isAdminOrAbove(); }

    // Question pool collections
    match /a1Pool/{docId} { allow read: if signedIn(); allow create, update, delete: if isAdminOrAbove(); }
    match /a2Pool/{docId} { allow read: if signedIn(); allow create, update, delete: if isAdminOrAbove(); }
    match /b1Pool/{docId} { allow read: if signedIn(); allow create, update, delete: if isAdminOrAbove(); }
    match /b2Pool/{docId} { allow read: if signedIn(); allow create, update, delete: if isAdminOrAbove(); }
    match /c1Pool/{docId} { allow read: if signedIn(); allow create, update, delete: if isAdminOrAbove(); }
    match /c2Pool/{docId} { allow read: if signedIn(); allow create, update, delete: if isAdminOrAbove(); }

    match /ielts/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdminOrAbove();
    }

    match /questions/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdminOrAbove();
    }

    // students collection (CEFR student records) — admin and above
    match /students/{docId} {
      allow read: if isAdminOrAbove();
      allow create, update, delete: if isAdminOrAbove();
    }

    match /results/{document=**} {
      allow read: if isAdminOrAbove()
                  || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow list, get: if isAdminOrAbove();
      allow update, delete: if isAdminOrAbove();
    }

    // ── Config collections — superadmin writes, anyone reads ──────────────────
    match /settings/{docId}      { allow read: if isAdminOrAbove(); allow write: if isSuperadmin(); }
    match /statistics/{docId}    { allow read: if isAdminOrAbove(); allow write: if isAdminOrAbove(); }
    match /announcements/{docId} { allow read: if true;             allow write: if isAdminOrAbove(); }
    match /levels/{docId}        { allow read: if signedIn();       allow write: if isAdminOrAbove(); }
    match /services/{docId}      { allow read: if true;             allow write: if isSuperadmin(); }
    match /features/{docId}      { allow read: if true;             allow write: if isSuperadmin(); }

    // ── Catch-all: deny everything not explicitly allowed ─────────────────────
    match /{document=**} {
      allow read: if isAdminOrAbove();
      allow write: if isSuperadmin();
    }
  }
}
