rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userRole() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isSuperadmin() {
      return userRole() == 'superadmin';
    }

    function isAdminOrAbove() {
      return userRole() == 'superadmin' || userRole() == 'admin';
    }

    match /users/{userId} {
      allow create: if signedIn();

      // User can read their own doc; superadmin/admin can read any
      allow get:  if signedIn() && (request.auth.uid == userId || isAdminOrAbove());
      allow list: if signedIn() && isAdminOrAbove();
      allow read: if signedIn() && (request.auth.uid == userId || isAdminOrAbove());

      // User can update own profile — but NOT the role field
      allow update: if signedIn()
                       && request.auth.uid == userId
                       && !('role' in request.resource.data.diff(resource.data).affectedKeys());

      // Only superadmin can change any user's role
      allow update: if isSuperadmin();
    }

    match /roleAuditLog/{docId} {
      allow create: if isSuperadmin();
      allow read:   if isSuperadmin();
    }

    match /tests/{docId} {
      allow read: if true;
      allow create, update, delete: if isSuperadmin();
    }

    // Dynamic level-based test collections
    match /a1Tests/{docId} {
      allow read: if true;
      allow create, update, delete: if isSuperadmin();
    }

    match /a2Tests/{docId} {
      allow read: if true;
      allow create, update, delete: if isSuperadmin();
    }

    match /b1Tests/{docId} {
      allow read: if true;
      allow create, update, delete: if isSuperadmin();
    }

    match /b2Tests/{docId} {
      allow read: if true;
      allow create, update, delete: if isSuperadmin();
    }

    match /c1Tests/{docId} {
      allow read: if true;
      allow create, update, delete: if isSuperadmin();
    }

    match /c2Tests/{docId} {
      allow read: if true;
      allow create, update, delete: if isSuperadmin();
    }

    match /students/{docId} {
      allow read: if true;
      allow create, update, delete: if isSuperadmin();
    }

    match /ielts/{docId} {
      allow read: if true;
      allow create, update, delete: if isSuperadmin();
    }

    // Question pool collections
    match /a1Pool/{docId} {
      allow read: if true;
      allow create, update, delete: if isSuperadmin();
    }

    match /a2Pool/{docId} {
      allow read: if true;
      allow create, update, delete: if isSuperadmin();
    }

    match /b1Pool/{docId} {
      allow read: if true;
      allow create, update, delete: if isSuperadmin();
    }

    match /b2Pool/{docId} {
      allow read: if true;
      allow create, update, delete: if isSuperadmin();
    }

    match /c1Pool/{docId} {
      allow read: if true;
      allow create, update, delete: if isSuperadmin();
    }

    match /c2Pool/{docId} {
      allow read: if true;
      allow create, update, delete: if isSuperadmin();
    }

    match /results/{document=**} {
      allow read: if isSuperadmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow list, get: if isSuperadmin();
      allow update, delete: if isSuperadmin();
    }

    match /{document=**} {
      allow read: if isSuperadmin() || signedIn();
      allow list: if isSuperadmin();
      allow write: if isSuperadmin();
    }
  }
}
